{
  "name": "ollama-copilot",
  "displayName": "Ollama for GitHub Copilot",
  "version": "0.1.0",
  "description": "Run Ollama models with full tool and vision support in GitHub Copilot Chat. Manage local and remote Ollama instances directly from VS Code.",
  "categories": [
    "AI",
    "Chat",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "chat",
    "code assistant",
    "coding",
    "copilot",
    "llama",
    "local",
    "models",
    "ollama",
    "tools",
    "vision"
  ],
  "license": "MIT",
  "author": {
    "name": "Daniel Sieradski",
    "email": "daniel@self.agency",
    "url": "https://self.agency"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/ollama-copilot.git"
  },
  "qna": "marketplace",
  "publisher": "selfagency",
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "task compile",
    "prepare": "husky",
    "test": "task unit-tests",
    "test:coverage": "task unit-test-coverage",
    "test:extension": "task extension-tests",
    "test:integration": "task integration-tests"
  },
  "dependencies": {
    "ollama": "^0.6.3"
  },
  "devDependencies": {
    "@go-task/cli": "^3.49.0",
    "@octokit/rest": "^22.0.1",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.109.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/dts": "^0.4.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "assert": "^2.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "npm-run-all": "^4.1.5",
    "ora": "^9.3.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vscode": "^1.1.37",
    "zx": "^8.8.5"
  },
  "lint-staged": {
    "scripts/*.mjs": [
      "task precommit -- "
    ],
    "src/**/*.ts": [
      "task precommit -- "
    ],
    "**/*.{json,yml,yaml,md}": [
      "oxfmt --write"
    ]
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "ollama-copilot.ollama",
        "name": "ollama",
        "fullName": "Ollama",
        "description": "Chat with an Ollama model",
        "isSticky": true
      }
    ],
    "commands": [
      {
        "command": "ollama-copilot.manageAuthToken",
        "title": "Manage Ollama Auth Token",
        "icon": "$(key)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.refreshModels",
        "title": "Refresh Ollama Models",
        "icon": "$(refresh)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.filterLocalModels",
        "title": "Filter Local Models",
        "icon": "$(filter)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.clearLocalFilter",
        "title": "Clear Local Models Filter",
        "icon": "$(clear-all)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.filterCloudModels",
        "title": "Filter Cloud Models",
        "icon": "$(filter)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.clearCloudFilter",
        "title": "Clear Cloud Models Filter",
        "icon": "$(clear-all)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.filterLibraryModels",
        "title": "Filter Library Models",
        "icon": "$(filter)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.clearLibraryFilter",
        "title": "Clear Library Models Filter",
        "icon": "$(clear-all)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.toggleLocalGrouping",
        "title": "Show as Flat List",
        "icon": "$(list-flat)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.toggleLocalGroupingToTree",
        "title": "Show as Tree",
        "icon": "$(list-tree)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.toggleCloudGrouping",
        "title": "Show as Flat List",
        "icon": "$(list-flat)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.toggleCloudGroupingToTree",
        "title": "Show as Tree",
        "icon": "$(list-tree)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.toggleLibraryGrouping",
        "title": "Show as Flat List",
        "icon": "$(list-flat)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.toggleLibraryGroupingToTree",
        "title": "Show as Tree",
        "icon": "$(list-tree)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.collapseLocalModels",
        "title": "Collapse All Local Models",
        "icon": "$(collapse-all)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.collapseCloudModels",
        "title": "Collapse All Cloud Models",
        "icon": "$(collapse-all)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.collapseLibrary",
        "title": "Collapse All Library Models",
        "icon": "$(collapse-all)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.refreshSidebar",
        "title": "Refresh Local Ollama Models",
        "icon": "$(refresh)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.refreshLocalModels",
        "title": "Refresh Local Ollama Models",
        "icon": "$(refresh)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.refreshLibrary",
        "title": "Refresh Ollama Library",
        "icon": "$(refresh)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.deleteModel",
        "title": "Delete Ollama Model",
        "icon": "$(trash)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.pullModel",
        "title": "Pull Ollama Model",
        "icon": "$(cloud-download)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.stopModel",
        "title": "Stop Ollama Model",
        "icon": "$(debug-stop)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.startModel",
        "title": "Start Ollama Model",
        "icon": "$(debug-start)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.pullModelFromLibrary",
        "title": "Pull Ollama Model",
        "icon": "$(cloud-download)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.openLibraryModelPage",
        "title": "Open Ollama Model Page",
        "icon": "$(link)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.refreshCloudModels",
        "title": "Refresh Ollama Cloud Models",
        "icon": "$(refresh)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.manageCloudApiKey",
        "title": "Manage Ollama Cloud API Key",
        "icon": "$(key)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.openCloudModel",
        "title": "Open Ollama Cloud Model Page",
        "icon": "$(link)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.startCloudModel",
        "title": "Run Ollama Cloud Model",
        "icon": "$(debug-start)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.stopCloudModel",
        "title": "Stop Ollama Cloud Model",
        "icon": "$(debug-stop)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.refreshModelfiles",
        "title": "Refresh Modelfiles",
        "icon": "$(refresh)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.newModelfile",
        "title": "New Modelfile",
        "icon": "$(add)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.editModelfile",
        "title": "Edit Modelfile",
        "icon": "$(edit)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.buildModelfile",
        "title": "Build Model from Modelfile",
        "icon": "$(rocket)",
        "category": "Ollama"
      },
      {
        "command": "ollama-copilot.openModelfilesFolder",
        "title": "Open Modelfiles Folder",
        "icon": "$(folder-opened)",
        "category": "Ollama"
      }
    ],
    "configuration": {
      "title": "Ollama",
      "properties": {
        "ollama.host": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL (local or remote)"
        },
        "ollama.contextLength": {
          "type": "number",
          "default": 0,
          "description": "Override context window size (0 = use model default)"
        },
        "ollama.localModelRefreshInterval": {
          "type": "number",
          "default": 30,
          "description": "Auto-refresh local and running models interval in seconds"
        },
        "ollama.libraryRefreshInterval": {
          "type": "number",
          "default": 21600,
          "description": "Auto-refresh library and cloud model catalogs interval in seconds (default 6 hours)"
        },
        "ollama.streamLogs": {
          "type": "boolean",
          "default": true,
          "description": "Stream Ollama server logs to output channel"
        },
        "ollama.diagnostics.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "description": "Controls Ollama extension diagnostics verbosity in the output channel"
        },
        "ollama.modelfilesPath": {
          "type": "string",
          "default": "",
          "description": "Path to folder containing Modelfiles. Leave empty to use ~/.ollama/modelfiles"
        },
        "ollama.completionModel": {
          "type": "string",
          "default": "",
          "markdownDescription": "Model used for inline code completions. Leave empty to disable. Smaller, faster models work best (e.g. `qwen2.5-coder:1.5b`, `deepseek-coder:1.3b`)."
        },
        "ollama.enableInlineCompletions": {
          "type": "boolean",
          "default": true,
          "description": "Enable Ollama inline code completions."
        }
      }
    },
    "grammars": [
      {
        "language": "modelfile",
        "scopeName": "source.modelfile",
        "path": "./syntaxes/modelfile.tmLanguage.json"
      }
    ],
    "languageModelChatProviders": [
      {
        "vendor": "selfagency-ollama",
        "displayName": "🦙 Ollama",
        "managementCommand": "ollama-copilot.manageAuthToken"
      }
    ],
    "languages": [
      {
        "id": "modelfile",
        "aliases": [
          "Modelfile"
        ],
        "extensions": [
          ".modelfile"
        ],
        "filenames": [
          "Modelfile"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ollama-copilot.manageAuthToken",
          "when": "view == ollama-local-models",
          "group": "navigation@0"
        },
        {
          "command": "ollama-copilot.filterLocalModels",
          "when": "view == ollama-local-models && !ollama.localFilterActive",
          "group": "navigation@1"
        },
        {
          "command": "ollama-copilot.clearLocalFilter",
          "when": "view == ollama-local-models && ollama.localFilterActive",
          "group": "navigation@1"
        },
        {
          "command": "ollama-copilot.toggleLocalGrouping",
          "when": "view == ollama-local-models && ollama.localGrouped",
          "group": "navigation@2"
        },
        {
          "command": "ollama-copilot.toggleLocalGroupingToTree",
          "when": "view == ollama-local-models && !ollama.localGrouped",
          "group": "navigation@2"
        },
        {
          "command": "ollama-copilot.refreshLocalModels",
          "when": "view == ollama-local-models",
          "group": "navigation@3"
        },
        {
          "command": "ollama-copilot.collapseLocalModels",
          "when": "view == ollama-local-models",
          "group": "navigation@4"
        },
        {
          "command": "ollama-copilot.filterLibraryModels",
          "when": "view == ollama-library-models && !ollama.libraryFilterActive",
          "group": "navigation@0"
        },
        {
          "command": "ollama-copilot.clearLibraryFilter",
          "when": "view == ollama-library-models && ollama.libraryFilterActive",
          "group": "navigation@0"
        },
        {
          "command": "ollama-copilot.toggleLibraryGrouping",
          "when": "view == ollama-library-models && ollama.libraryGrouped",
          "group": "navigation@1"
        },
        {
          "command": "ollama-copilot.toggleLibraryGroupingToTree",
          "when": "view == ollama-library-models && !ollama.libraryGrouped",
          "group": "navigation@1"
        },
        {
          "command": "ollama-copilot.refreshLibrary",
          "when": "view == ollama-library-models",
          "group": "navigation@2"
        },
        {
          "command": "ollama-copilot.collapseLibrary",
          "when": "view == ollama-library-models",
          "group": "navigation@3"
        },
        {
          "command": "ollama-copilot.manageCloudApiKey",
          "when": "view == ollama-cloud-models",
          "group": "navigation@0"
        },
        {
          "command": "ollama-copilot.filterCloudModels",
          "when": "view == ollama-cloud-models && !ollama.cloudFilterActive",
          "group": "navigation@1"
        },
        {
          "command": "ollama-copilot.clearCloudFilter",
          "when": "view == ollama-cloud-models && ollama.cloudFilterActive",
          "group": "navigation@1"
        },
        {
          "command": "ollama-copilot.toggleCloudGrouping",
          "when": "view == ollama-cloud-models && ollama.cloudGrouped",
          "group": "navigation@2"
        },
        {
          "command": "ollama-copilot.toggleCloudGroupingToTree",
          "when": "view == ollama-cloud-models && !ollama.cloudGrouped",
          "group": "navigation@2"
        },
        {
          "command": "ollama-copilot.refreshCloudModels",
          "when": "view == ollama-cloud-models",
          "group": "navigation@3"
        },
        {
          "command": "ollama-copilot.collapseCloudModels",
          "when": "view == ollama-cloud-models",
          "group": "navigation@4"
        },
        {
          "command": "ollama-copilot.newModelfile",
          "when": "view == ollama-modelfiles",
          "group": "navigation@0"
        },
        {
          "command": "ollama-copilot.openModelfilesFolder",
          "when": "view == ollama-modelfiles",
          "group": "navigation@1"
        },
        {
          "command": "ollama-copilot.refreshModelfiles",
          "when": "view == ollama-modelfiles",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "ollama-copilot.deleteModel",
          "when": "view == ollama-local-models && viewItem == local-stopped",
          "group": "inline@3"
        },
        {
          "command": "ollama-copilot.stopModel",
          "when": "view == ollama-local-models && viewItem == local-running",
          "group": "inline@2"
        },
        {
          "command": "ollama-copilot.startModel",
          "when": "view == ollama-local-models && viewItem == local-stopped",
          "group": "inline@1"
        },
        {
          "command": "ollama-copilot.pullModelFromLibrary",
          "when": "view == ollama-library-models && viewItem == library-model-variant",
          "group": "inline@1"
        },
        {
          "command": "ollama-copilot.pullModelFromLibrary",
          "when": "view == ollama-library-models && viewItem == library-model-downloaded-variant",
          "group": "inline@1"
        },
        {
          "command": "ollama-copilot.openLibraryModelPage",
          "when": "view == ollama-library-models && viewItem == library-model",
          "group": "inline@1"
        },
        {
          "command": "ollama-copilot.openCloudModel",
          "when": "view == ollama-cloud-models && viewItem == cloud-stopped",
          "group": "inline@1"
        },
        {
          "command": "ollama-copilot.startCloudModel",
          "when": "view == ollama-cloud-models && viewItem == cloud-stopped",
          "group": "inline@2"
        },
        {
          "command": "ollama-copilot.deleteModel",
          "when": "view == ollama-cloud-models && viewItem == cloud-stopped",
          "group": "inline@3"
        },
        {
          "command": "ollama-copilot.openCloudModel",
          "when": "view == ollama-cloud-models && viewItem == cloud-running",
          "group": "inline@1"
        },
        {
          "command": "ollama-copilot.stopCloudModel",
          "when": "view == ollama-cloud-models && viewItem == cloud-running",
          "group": "inline@2"
        },
        {
          "command": "ollama-copilot.editModelfile",
          "when": "view == ollama-modelfiles && viewItem == modelfile",
          "group": "inline@1"
        },
        {
          "command": "ollama-copilot.buildModelfile",
          "when": "view == ollama-modelfiles && viewItem == modelfile",
          "group": "inline@2"
        }
      ]
    },
    "views": {
      "ollama-explorer": [
        {
          "icon": "$(list-flat)",
          "id": "ollama-local-models",
          "name": "Local Models"
        },
        {
          "icon": "$(list-flat)",
          "id": "ollama-cloud-models",
          "name": "Cloud Models"
        },
        {
          "icon": "$(list-flat)",
          "id": "ollama-library-models",
          "name": "Library"
        },
        {
          "icon": "$(list-flat)",
          "id": "ollama-modelfiles",
          "name": "Modelfiles"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ollama-explorer",
          "title": "Ollama",
          "icon": "ollama.svg"
        }
      ]
    }
  },
  "activationEvents": [
    "onChatParticipant:ollama-copilot.ollama",
    "onLanguageModelChatProvider:selfagency-ollama",
    "onStartupFinished"
  ],
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
