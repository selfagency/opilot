        {
          "command": "opilot.openModelSettingsForModel",
          "when": "view == ollama-cloud-models && viewItem == cloud-stopped",
          "group": "inline@2"
        },
        {
          "command": "opilot.startCloudModel",
          "when": "view == ollama-cloud-models && viewItem == cloud-stopped",
          "group": "inline@3"
        },
        {
          "command": "opilot.deleteModel",
          "when": "view == ollama-cloud-models && viewItem == cloud-stopped",
          "group": "inline@4"
        },
        {
          "command": "opilot.openCloudModel",
          "when": "view == ollama-cloud-models && viewItem == cloud-running",
          "group": "inline@1"
        },
        {
          "command": "opilot.openModelSettingsForModel",
          "when": "view == ollama-cloud-models && viewItem == cloud-running",
          "group": "inline@2"
        },
        {
          "command": "opilot.stopCloudModel",
          "when": "view == ollama-cloud-models && viewItem == cloud-running",
          "group": "inline@3"
        },
        {
          "command": "opilot.editModelfile",
          "when": "view == ollama-modelfiles && viewItem == modelfile",
          "group": "inline@1"
        },
        {
          "command": "opilot.buildModelfile",
          "when": "view == ollama-modelfiles && viewItem == modelfile",
          "group": "inline@2"
        }
      ]
    },
    "views": {
      "ollama-explorer": [
        {
          "icon": "$(list-flat)",
          "id": "ollama-local-models",
          "name": "Local Models"
        },
        {
          "icon": "$(list-flat)",
          "id": "ollama-cloud-models",
          "name": "Cloud Models"
        },
        {
          "icon": "$(list-flat)",
          "id": "ollama-library-models",
          "name": "Library"
        },
        {
          "icon": "$(settings-gear)",
          "id": "ollama-model-settings",
          "name": "Model Settings",
          "type": "webview"
        },
        {
          "icon": "$(list-flat)",
          "id": "ollama-modelfiles",
          "name": "Modelfiles"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ollama-explorer",
          "title": "Ollama",
          "icon": "ollama.svg"
        }
      ]
    }
  },
