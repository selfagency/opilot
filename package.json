{
  "name": "opilot",
  "displayName": "Opilot",
  "version": "1.5.0",
  "description": "Run Ollama models with full tool and vision support in GitHub Copilot Chat. Manage local and remote Ollama instances directly from VS Code.",
  "categories": [
    "AI",
    "Chat",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "chat",
    "code assistant",
    "coding",
    "copilot",
    "llama",
    "local",
    "models",
    "ollama",
    "tools",
    "vision"
  ],
  "homepage": "https://opilot.self.agency",
  "license": "MIT",
  "author": {
    "name": "Daniel Sieradski",
    "email": "daniel@self.agency",
    "url": "https://self.agency"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/selfagency/opilot.git"
  },
  "qna": "marketplace",
  "publisher": "selfagency",
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "task compile",
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview",
    "prepare": "husky",
    "test": "task unit-tests",
    "test:coverage": "task unit-test-coverage",
    "test:extension": "task extension-tests",
    "test:integration": "task integration-tests"
  },
  "dependencies": {
    "@selfagency/llm-stream-parser": "^0.1.5",
    "ollama": "^0.6.3"
  },
  "devDependencies": {
    "@go-task/cli": "^3.49.1",
    "@octokit/rest": "^22.0.1",
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.110.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vscode/dts": "^0.4.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "assert": "^2.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.0",
    "npm-run-all": "^4.1.5",
    "ora": "^9.3.0",
